# Production endpoint (default). Comment out for local dev against your
# laptop's API; use the LAN IP, not localhost — RN simulator can't reach
# host loopback on a phone. Find IP with: ipconfig getifaddr en0
EXPO_PUBLIC_API_BASE_URL=https://cadence-api.gilla.fun
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.10:8080

# From Firebase console — Google OAuth Web client ID for the cadence-habit project.
# Used by @react-native-google-signin/google-signin to validate ID tokens.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# iOS-specific OAuth client (optional but recommended)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
