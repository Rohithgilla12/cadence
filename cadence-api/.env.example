# cadence-api environment
# Copy to .env for local dev. Never commit .env.

PORT=8080
CADENCE_ENV=development

# Postgres — Phase 1+ (PRD §13)
DATABASE_URL=postgres://cadence:cadence@localhost:5432/cadence?sslmode=disable

# Firebase Admin SDK — Phase 1 auth (PRD §15)
# Path to service account JSON (never commit the file itself)
FIREBASE_ADMIN_CREDENTIALS=

# Strava OAuth — Phase 4 (PRD §9)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=

# Sentry — observability
SENTRY_DSN=
