# Production environment for the Cadence API stack.
# Copy to .env on the VPS (or paste these as Portainer stack env vars).
# Never commit a populated .env.

# Required — Postgres
POSTGRES_PASSWORD=

# Required — Cloudflare tunnel token from Zero Trust dashboard
# (https://one.dash.cloudflare.com → Networks → Tunnels → cadence → "Install connector")
CLOUDFLARED_TUNNEL_TOKEN=

# Required — absolute host path to the Firebase Admin SDK service-account JSON
# Example: /home/gilla/cadence-secrets/firebase-admin.json
FIREBASE_CREDENTIALS_HOST_PATH=

# Required — which API image to pull. Pin to a :sha tag for production;
# :latest is convenient for first deploy but means rollbacks are tricky.
# Example: ghcr.io/rohithgilla12/cadence-api:e90c2ae
CADENCE_IMAGE=ghcr.io/rohithgilla12/cadence-api:latest

# Optional — Sentry DSN for error reporting
SENTRY_DSN=
